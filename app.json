{
  "expo": {
    "name": "Namaz Mentor",
    "slug": "namaz-mentor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#021226"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.namazmentor.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to calculate accurate prayer times and Qibla direction."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#021226"
      },
      "package": "com.namazmentor.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#021226"
        }
      ]
    ]
  }
}
