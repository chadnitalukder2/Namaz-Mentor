{
  "expo": {
    "name": "Namaz Mentor",
    "slug": "namaz-mentor",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#021226"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.namazmentor.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to calculate accurate prayer times and Qibla direction.",
        "NSUserNotificationsUsageDescription": "Namaz Mentor uses notifications to remind you when each prayer begins."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#021226"
      },
      "package": "com.namazmentor.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/adhan.wav"
          ]
        }
      ]
    ]
  }
}
